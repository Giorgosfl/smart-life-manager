# Tuya Cloud Project credentials
# Get these from https://platform.tuya.com → Your Project → Overview
TUYA_CLIENT_ID=your_client_id
TUYA_CLIENT_SECRET=your_client_secret

# Tuya API base URL — depends on your data center region:
#   Central Europe: https://openapi.tuyaeu.com
#   Western Europe: https://openapi-weaz.tuyaeu.com
#   Eastern America: https://openapi.tuyaus.com
#   Western America: https://openapi-ueaz.tuyaus.com
#   China:           https://openapi.tuyacn.com
#   India:           https://openapi.tuyain.com
TUYA_BASE_URL=https://openapi.tuyaeu.com

# Your Smart Life app account UID
# Get this from https://platform.tuya.com → Your Project → Devices → Link App Account
# It's the UID column in the linked accounts table (NOT the token UID from the API)
TUYA_APP_UID=your_app_uid
